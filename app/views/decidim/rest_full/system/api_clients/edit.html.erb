<% add_decidim_page_title(@api_client.name) %>
<% provide :title do %>
  <%= link_to t(".go_back"), system_api_clients_path, class: "button button__sm button__text-primary" %>
  <h1 class="h1"><%= @api_client.name %></h1>
<% end %>

<div class="w-full">
  <div>
    <nav class="flex space-x-4" aria-label="Tabs">
      <button type="button" id="tab-info" class="js-tab-button px-4 py-2 text-sm font-medium rounded-lg bg-primary text-white border border-primary" data-tab="info" aria-current="page">
        <%= t(".permissions", default: "Permissions") %>
      </button>
      <button type="button" id="tab-webhook" class="js-tab-button px-4 py-2 text-sm font-medium rounded-lg bg-white text-gray-700 border border-gray-300 hover:bg-gray-50" data-tab="webhook">
        <%= t(".webhook", default: "Webhook") %>
      </button>
    </nav>
  </div>
  <div class="mt-6">
    <div id="tab-content-info" class="tab-content">
      <%= render partial: "decidim/rest_full/system/api_clients/edit_info_tab" %>
    </div>
    <div id="tab-content-webhook" class="tab-content hidden">
      <%= render partial: "decidim/rest_full/system/api_clients/edit_webhook_tab" %>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabButtons = document.querySelectorAll('.js-tab-button');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach(button => {
      button.addEventListener('click', function() {
        const targetTab = this.getAttribute('data-tab');

        // Update button styles - inactive: outlined, active: filled
        tabButtons.forEach(btn => {
          btn.classList.remove('bg-primary', 'text-white', 'border-primary');
          btn.classList.add('bg-white', 'text-gray-700', 'border-gray-300', 'hover:bg-gray-50');
        });
        this.classList.remove('bg-white', 'text-gray-700', 'border-gray-300', 'hover:bg-gray-50');
        this.classList.add('bg-primary', 'text-white', 'border-primary');

        // Show/hide content
        tabContents.forEach(content => {
          content.classList.add('hidden');
        });
        document.getElementById(`tab-content-${targetTab}`).classList.remove('hidden');
      });
    });
  });
</script>
