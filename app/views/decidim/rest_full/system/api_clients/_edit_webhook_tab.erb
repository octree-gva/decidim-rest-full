<% webhook_registrations = Decidim::RestFull::WebhookRegistration.where(api_client_id: @api_client.id) %>

<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h2 class="h2"><%= t(".webhook_registrations", default: "Webhook Registrations") %></h2>
    <button type="button" class="button button__sm button__primary" onclick="document.getElementById('new-webhook-form').classList.toggle('hidden')">
      <%= t(".add_webhook", default: "Add Webhook") %>
    </button>
  </div>

  <div id="new-webhook-form" class="hidden p-4 bg-gray-50 rounded-lg border border-gray-200">
    <%= form_for(Decidim::RestFull::WebhookRegistrationForm.new, url: system_webhook_registrations_path, html: { class: "space-y-4" }) do |form| %>
      <%= hidden_field_tag "webhook_registration_form[api_client_id]", @api_client.id %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2 required"><%= t(".url", default: "URL") %></label>
        <%= text_field_tag "webhook_registration_form[url]", nil, placeholder: "https://example.com/webhook", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2"><%= t(".subscriptions", default: "Subscriptions") %></label>
        <div class="space-y-2">
          <% available_events = @api_client.permissions.events.pluck(:permission) %>
          <% available_events.each do |event| %>
            <label class="flex items-center gap-2">
              <%= check_box_tag "webhook_registration_form[subscriptions][]", event, false, class: "rounded border-gray-300 text-primary focus:ring-primary" %>
              <span class="text-sm text-gray-700"><%= event %></span>
            </label>
          <% end %>
        </div>
      </div>
      <div class="flex justify-end gap-2">
        <button type="button" onclick="document.getElementById('new-webhook-form').classList.add('hidden')" class="button button__sm button__text-primary">
          <%= t(".cancel", default: "Cancel") %>
        </button>
        <%= form.submit t(".create", default: "Create"), class: "button button__sm button__primary" %>
      </div>
    <% end %>
  </div>

  <% if webhook_registrations.any? %>
    <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 rounded-lg">
      <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t(".url", default: "URL") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t(".subscriptions", default: "Subscriptions") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t(".created_at", default: "Created At") %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t(".actions", default: "Actions") %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% webhook_registrations.each do |webhook| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= webhook.url %></td>
              <td class="px-6 py-4 text-sm text-gray-500">
                <div class="flex flex-wrap gap-1">
                  <% webhook.subscriptions.each do |subscription| %>
                    <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-gray-100 text-gray-800"><%= subscription %></span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= l webhook.created_at, format: :short %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to t(".delete", default: "Delete"), system_webhook_registration_path(webhook), method: :delete, data: { confirm: t(".confirm_delete", default: "Are you sure?") }, class: "text-red-600 hover:text-red-900" %>              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-12 bg-gray-50 rounded-lg border border-gray-200">
      <p class="text-gray-500"><%= t(".no_webhooks", default: "No webhook registrations found.") %></p>
    </div>
  <% end %>
</div>
