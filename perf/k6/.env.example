# Copy to perf/k6/.env and fill in (never commit secrets).
#
# Docker (docker-compose.perf.yml + --profile perf): k6 uses the Compose network
# Host k6 against published port 3000: use http://localhost:3000

K6_BASE_URL=http://rest_full:3000
K6_API_PREFIX=/api/rest_full/v0.3

# Client credentials (machine token)
K6_CLIENT_ID=
K6_CLIENT_SECRET=
K6_CLIENT_SCOPES=public proposals blogs system

# Impersonation / ROPC (user token for writes)
K6_USER_EMAIL=
K6_USER_PASSWORD=
K6_IMPERSONATION_SCOPES=proposals blogs system

# Fixture ids from your staging seed
K6_SPACE_MANIFEST=participatory_processes
K6_SPACE_ID=
K6_COMPONENT_ID=
K6_BLOG_POST_ID=
K6_PROPOSAL_ID=
K6_DRAFT_PROPOSAL_ID=
K6_USER_ID=
