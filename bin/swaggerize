#!/bin/bash
set -e

# Disable SimpleCov when generating the OpenAPI spec so that
# coverage formatters (e.g. Cobertura) cannot break the task.
unset SIMPLECOV

# Default values for options
QUIET=0
OUTPUT_FILE="./openapi.json"

# Print messages unless quiet mode is active
log() {
  if [[ $QUIET -eq 0 ]]; then
    echo "$@"
  fi
}

# Help menu
show_help() {
  cat <<EOF
Usage: $0 [options]

Options:
  --quiet, -q       Suppress output messages.
  --out, -o FILE    Specify the output file (default: $OUTPUT_FILE).
  --help, -h        Display this help menu.

Extra RSpec paths (beyond spec/requests): set DECIDIM_REST_FULL_SWAGGER_SPEC_PATHS
to comma-separated globs, and/or add spec/rest_full_swagger_spec_paths.rb calling
Decidim::RestFull::Core::SwaggerSpecPaths.register(...).
EOF
}

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --quiet|-q)
      QUIET=1
      shift
      ;;
    --out|-o)
      OUTPUT_FILE="$2"
      shift 2
      ;;
    --help|-h)
      show_help
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      show_help
      exit 1
      ;;
  esac
done

cd "$ROOT"
bundle check || bundle install
log "Generating OpenAPI spec"
log "~~~~~~~~~~~~~~~~~~~~~~~"
log "quiet: $QUIET"
log "output: $OUTPUT_FILE"
log "~~~~~~~~~~~~~~~~~~~~~~~"

RSPEC_TARGETS="$(bundle exec ruby -I lib -e '
  require "decidim/rest_full/core/swagger_spec_paths"
  hook = File.expand_path("spec/rest_full_swagger_spec_paths.rb", Dir.pwd)
  load hook if File.exist?(hook)
  print Decidim::RestFull::Core::SwaggerSpecPaths.rspec_paths.join(" ")
')"
log "rspec targets: $RSPEC_TARGETS"

# Ensure dummy app test DB is migrated (e.g. when run in a fresh container after setup-tests)
if [[ -d spec/decidim_dummy_app ]] && [[ -n "${DATABASE_URL:-}" ]]; then
  cd spec/decidim_dummy_app
  log "> bundle check || bundle install"
  RAILS_ENV=test bundle check || bundle install
  log "> rake db:create db:migrate"
  RAILS_ENV=test bundle exec rake db:create db:migrate
  cd ../..
fi

log "> rspec $RSPEC_TARGETS"
if [[ $QUIET -eq 1 ]]; then
  SWAGGER_DRY_RUN=0 bundle exec rspec $RSPEC_TARGETS \
    --format Rswag::Specs::SwaggerFormatter > /dev/null 2>&1
else
  SWAGGER_DRY_RUN=0 bundle exec rspec $RSPEC_TARGETS \
    --format Rswag::Specs::SwaggerFormatter
fi

mv -f spec/decidim_dummy_app/swagger/v1/swagger.json "$OUTPUT_FILE"

bundle exec ruby - "$OUTPUT_FILE" <<'RUBY'
path = ARGV.fetch(0)
doc = JSON.parse(File.read(path))
doc.fetch("paths", {}).each_value do |methods|
  methods.each_value do |operation|
    params = operation["parameters"]
    next unless params.is_a?(Array)

    seen = {}
    operation["parameters"] = params.reject do |param|
      key = [param["name"], param["in"]]
      next false unless key[0]

      if seen[key]
        true
      else
        seen[key] = true
        false
      end
    end
  end
end
File.write(path, JSON.pretty_generate(doc))
RUBY

log "done, $OUTPUT_FILE written."
