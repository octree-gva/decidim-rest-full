#! /bin/bash
# This scripts aims to run in a docker ruby: container.
set -euxo pipefail
export CI=1
export NODE_ENV=development
export RAILS_ENV=test

echo "Installing dependencies"
apt-get update -qq && apt-get install -y ca-certificates curl gnupg libpq-dev
gem install pg

# if node is not installed, install it
if ! command -v node &> /dev/null; then
  echo "Installing Node.js"
  mkdir -p /etc/apt/keyrings
  curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg
  echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_$NODE_MAJOR.x nodistro main" | tee /etc/apt/sources.list.d/nodesource.list
  apt-get update -qq && apt-get install -y -qq nodejs
  npm install -g yarn --force
  corepack enable
fi

echo "Installing Decidim"
gem install bundler
bundle config set path 'vendor'
bundle install -j $(nproc)

rm -rf spec/decidim_dummy_app
# Ensure test DB exists before rake test_app (generator loads Rails env)
if [ -n "${DATABASE_HOST:-}" ]; then
  echo "Waiting for postgres at $DATABASE_HOST..."
  until ruby -r pg -e "PG.connect(host: ENV['DATABASE_HOST'], port: ENV.fetch('DATABASE_PORT','5432'), user: ENV['DATABASE_USERNAME'], password: ENV['DATABASE_PASSWORD'], dbname: 'postgres', connect_timeout: 2).close" 2>/dev/null; do sleep 2; done
  echo "Creating test database if missing..."
  ruby -r pg -e "
    c = PG.connect(host: ENV['DATABASE_HOST'], port: ENV.fetch('DATABASE_PORT','5432'), user: ENV['DATABASE_USERNAME'], password: ENV['DATABASE_PASSWORD'], dbname: 'postgres')
    begin
      c.exec('CREATE DATABASE decidim_module_rest_full_test_app_test')
    rescue PG::DuplicateDatabase
      nil
    ensure
      c.close
    end
  "
fi
echo "Generating Decidim dummy app"
bundle exec rake test_app
cd spec/decidim_dummy_app && bundle install
cd ../..

echo "Test app is ready"
